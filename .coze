[project]
requires = ["nodejs-24", "python-3.12"]
entrypoint = "frontend"

[dev]
build = ["bash", "-c", "pip install -r requirements.txt && cd frontend && pnpm install"]
run = ["bash", "-c", "(nohup python run_backend.py > /app/work/logs/bypass/backend.log 2>&1 &) && cd frontend && npx next dev -p 5000"]

[deploy]
build = ["bash", "-c", "pip install -r requirements.txt && cd frontend && pnpm install && pnpm run build"]
run = ["bash", "-c", "(nohup python run_backend.py > /app/work/logs/bypass/backend.log 2>&1 &) && cd frontend && npx next start -p 5000"]
